# 🔍 PocketFlow Tracing & Environment Template
# Copy this file to .env and replace placeholders with your credentials

# # ----------------------------------------------------
# # 🛡️ REQUIRED: LLM API KEYS
# # ----------------------------------------------------
# # Provide the api token matching your active Pi model provider
# # (e.g. OpenAI, Anthropic, or OpenRouter)
# OPENAI_API_KEY="your_key_here"
# ANTHROPIC_API_KEY="your_key_here"

# # OpenRouter Configuration (If using OpenRouter models in your workspace)
# OPENROUTER_API_KEY="your_key_here"
# OPENROUTER__BASE_URL="https://openrouter.ai/api"
# OPENROUTER_MODEL="google/gemini-2.5-flash"

# # ----------------------------------------------------
# # 📊 OPTIONAL: Langfuse Observability Tracing
# # ----------------------------------------------------
# # Fill in your key credentials to automatically dispatch 
# # all workflow node execution details straight to Langfuse
# LANGFUSE_PUBLIC_KEY="your_public_key_here"
# LANGFUSE_SECRET_KEY="your_secret_key_here"
# LANGFUSE_HOST="https://cloud.langfuse.com"

# # ----------------------------------------------------
# # 🎛️ OPTIONAL: Tracing Granularity & Debug Toggles 
# # ----------------------------------------------------
# # Set to 'true' to trace complete data mappings per phase,
# # or 'false' to keep input/outputs silent of trace records. 
# # POCKETFLOW_TRACING_DEBUG enables verbose logging of the tracing process itself, useful for debugging the integration. 
# # Disabling it will reduce log verbosity while still allowing you to trace inputs, outputs, and execution details based on the other toggles below.

# POCKETFLOW_TRACING_DEBUG=false
# POCKETFLOW_TRACE_INPUTS=true
# POCKETFLOW_TRACE_OUTPUTS=true
# POCKETFLOW_TRACE_PREP=true
# POCKETFLOW_TRACE_EXEC=true
# POCKETFLOW_TRACE_POST=true
# POCKETFLOW_TRACE_ERRORS=true

# # ----------------------------------------------------
# # 🛰️ OPTIONAL: Custom Session and User ID Tagging
# # ----------------------------------------------------
# # Track flows in Langfuse grouped by session identifiers
# POCKETFLOW_SESSION_ID=pi_agent_session
# POCKETFLOW_USER_ID=workspace_user

# ----------------------------------------------------
# 🎨 OPTIONAL: PocketFlow Diagram Visualization Toggles
# ----------------------------------------------------
# When set to 'true', it dynamically outputs a detailed 
# topological Mermaid flowchart and full code audits in a Markdown blueprint
POCKETFLOW_VISUALIZE=true
